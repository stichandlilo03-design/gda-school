# ==============================================================
# DATABASE (PostgreSQL - Use Neon, Supabase, or Railway)
# ==============================================================
# Neon (RECOMMENDED for Vercel): https://neon.tech
#   - Serverless PostgreSQL, auto-scales to zero
#   - Free tier: 0.5GB storage, 190 compute hours/mo
#   - Perfect Vercel integration (same region, connection pooling)
#
# Supabase: https://supabase.com
#   - PostgreSQL + built-in auth + storage + realtime
#   - Free tier: 500MB storage, 2 projects
#
# Railway: https://railway.app
#   - Simple PostgreSQL hosting
#   - $5/mo credit free tier
#
DATABASE_URL="postgresql://user:password@host:5432/gda_school?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/gda_school?sslmode=require"

# ==============================================================
# AUTH
# ==============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-generate-with-openssl-rand-base64-32"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ==============================================================
# FILE STORAGE (Pick one)
# ==============================================================
# Uploadthing (RECOMMENDED for Vercel): https://uploadthing.com
#   - Free tier: 2GB storage, 2GB bandwidth
#   - Dead simple React integration
#
# Cloudflare R2: https://developers.cloudflare.com/r2
#   - Free tier: 10GB storage, 10M requests
#   - S3-compatible API
#
# AWS S3: https://aws.amazon.com/s3
#   - Free tier: 5GB, 12 months
#
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# ==============================================================
# PAYMENTS
# ==============================================================
# Stripe: https://stripe.com (international)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Paystack: https://paystack.com (Africa)
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""

# Flutterwave: https://flutterwave.com (Africa)
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_PUBLIC_KEY=""

# ==============================================================
# EMAIL (Pick one)
# ==============================================================
# Resend (RECOMMENDED): https://resend.com
#   - Free tier: 100 emails/day, 3000/month
#   - Great DX, React Email support
#
# SendGrid: https://sendgrid.com
#   - Free tier: 100 emails/day
#
RESEND_API_KEY=""

# ==============================================================
# REDIS (for caching & sessions - optional but recommended)
# ==============================================================
# Upstash: https://upstash.com
#   - Serverless Redis, perfect for Vercel
#   - Free tier: 10,000 commands/day
#
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ==============================================================
# VIDEO CONFERENCING (for live classes)
# ==============================================================
# Agora: https://agora.io
#   - Free tier: 10,000 minutes/month
#
# Or self-host Jitsi: https://jitsi.org
#
AGORA_APP_ID=""
AGORA_APP_CERTIFICATE=""

# ==============================================================
# APP CONFIG
# ==============================================================
NEXT_PUBLIC_APP_NAME="Global Digital Academy"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
